{
    "manifest_version" : 3,
    "name" : "Gmail Phishing-Detector",
    "version" : "1.0",
    "description" : "Detect phishing Gmail using ML",
    "permissions" : [
        "activeTab",
        "scripting"
    ],
    "host_permissions" : [
        "https://mail.google.com/*",
        "https://127.0.0.1:8000/*"  
    ],
    "background" : {
        "service_worker" : "background.js"
    },
    "content_scripts" : [
        {
            "matches" : ["https://mail.google.com/*"],
            "js" : ["content.js"],
            "run_at" : "document_idle"
        }
    ]
}